# Copy this file to tesla_secrets.env and fill in the values.
# tesla_secrets.env is git-ignored. NEVER commit real secrets.
# This file is sourced by bash (gen_secrets.sh) — if a value contains spaces or
# special characters, wrap it in double quotes, e.g. WIFI_PASSWORD="my pass#1".

# --- WiFi the dashboard joins (used by the firmware) ---
WIFI_SSID=
WIFI_PASSWORD=

# --- From the Tesla developer portal (https://developer.tesla.com) ---
TESLA_CLIENT_ID=
TESLA_CLIENT_SECRET=

# The domain you control and have hosted the public key on.
TESLA_DOMAIN=onesandzeros.nz

# A redirect URI you registered in your app's "Allowed Redirect URIs".
# Can be a real callback page or a localhost URL — we only read the ?code= back.
TESLA_REDIRECT_URI=https://onesandzeros.nz/auth/tesla/callback

# Fleet API regional base URL (the "audience").
#   NA / Asia-Pacific (incl. New Zealand): https://fleet-api.prd.na.vn.cloud.tesla.com
#   Europe / Middle East / Africa:         https://fleet-api.prd.eu.vn.cloud.tesla.com
TESLA_AUDIENCE=https://fleet-api.prd.na.vn.cloud.tesla.com

# --- Produced by tools/tesla_setup.py (the firmware needs these two) ---
TESLA_REFRESH_TOKEN=
TESLA_ENERGY_SITE_ID=
